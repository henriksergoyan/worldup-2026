# Database (SQLite for local MVP). To move to Postgres, change the provider in
# prisma/schema.prisma to "postgresql" and update this URL.
DATABASE_URL="file:./dev.db"

# Secret used to sign session JWTs. Use a long random string in production.
AUTH_SECRET="dev-only-change-me-to-a-long-random-string"

# Default tournament timezone
TZ="Asia/Yerevan"
